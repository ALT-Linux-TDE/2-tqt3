.br
.ti -1c
.BI "\fBTQSqlRecordInfo\fR ( const TQSqlRecord & other )"
.br
.ti -1c
.BI "size_type \fBcontains\fR ( const TQString & fieldName ) const"
.br
.ti -1c
.BI "TQSqlFieldInfo \fBfind\fR ( const TQString & fieldName ) const"

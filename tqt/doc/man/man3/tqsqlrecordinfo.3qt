.SH NAME
TQSqlRecordInfo \- Encapsulates a set of database field meta data
.SH SYNOPSIS
\fC#include <tqsqlrecord.h>\fR
.PP
.SS "Public Members"
.in +1c
.ti -1c
.BI "\fBTQSqlRecordInfo\fR ()"
.br
.ti -1c

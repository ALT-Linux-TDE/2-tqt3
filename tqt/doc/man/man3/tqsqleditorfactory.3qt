.SH NAME
TQSqlEditorFactory \- Used to create the editors used by TQDataTable and TQSqlForm
.SH SYNOPSIS
\fC#include <tqsqleditorfactory.h>\fR
.PP
Inherits TQEditorFactory.
.PP
.SS "Public Members"
.in +1c
.ti -1c
.BI "\fBTQSqlEditorFactory\fR ( TQObject * parent = 0, const char * name = 0 )"
.br
.ti -1c

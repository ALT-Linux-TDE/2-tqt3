.BI "virtual TQWidget * \fBcreateEditor\fR ( TQWidget * parent, const TQVariant & variant )"
.br
.ti -1c
.BI "virtual TQWidget * \fBcreateEditor\fR ( TQWidget * parent, const TQSqlField * field )"
.br
.in -1c
